{
  "name": "romanica",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "rust:test": "cargo test --workspace",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:reset": "docker compose down -v && docker compose up -d && sleep 2 && bun run scripts/migrate.ts"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/bun": "^1.1.14"
  }
}
