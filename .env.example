# Postgres (matches docker-compose.yml — host port 5433 to avoid local PG clashes)
DATABASE_URL=postgres://romanica:romanica@127.0.0.1:5433/romanica

# Object store (S3-compatible — MinIO in docker-compose.yml)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=romanica-traces
S3_ACCESS_KEY_ID=romanica
S3_SECRET_ACCESS_KEY=romanica123

# API
API_PORT=4000

# Dashboard -> API
NEXT_PUBLIC_API_URL=http://localhost:4000
